# Supabase Configuration (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin API Key (REQUIRED for storage stats)
# WARNING: This key bypasses Row Level Security!
# Only use in server-side code or trusted environments
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application Settings
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SETTINGS_PASSWORD=your-secure-password

# GitHub Integration (Optional - for backup system)
GITHUB_PAT=your-github-personal-access-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=pendingsystem

# Node Environment
NODE_ENV=development
