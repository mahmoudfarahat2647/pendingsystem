									const isToday = day === calendarData.today;
									const isValid = day > 0 && day <= calendarData.daysInMonth;

									return (
										<span
											key={`calendar-day-${i}`}
											className={cn(
												"w-4 h-4 flex items-center justify-center rounded-full",
												isValid
													? "text-gray-500 hover:bg-white/10 cursor-pointer"
