					</Card>
				)}

				{showCharts ? (
					<Suspense
						fallback={
							<Card className="bg-[#0c0c0e] border border-white/10 rounded-xl">
								<CardContent className="p-6">
									<div className="h-[220px] bg-white/5 animate-pulse rounded-lg" />
