				value: new Set(callRowData.map((item: PendingRow) => item.vin)).size,
				subtext: "Unique Vehicles",
				icon: Phone,
			},
		],
		// خد بالك غيرنا الـ dependency array عشان يحس بأي تغيير في البيانات نفسها
		[rowData, ordersRowData, callRowData],
