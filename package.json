{
	"name": "pendingsystem",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev",
		"prepare": "husky install",
		"build": "next build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:fix:staged": "biome check --write --staged --no-errors-on-unmatched",
		"lint:fix:staged:unsafe": "biome check --write --unsafe --staged --no-errors-on-unmatched",
		"type-check": "tsc --noEmit",
		"start": "next start",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"docs": "echo 'Docs are in README.md, FEATURES.md, ENGINEERING.md'",
		"docs:serve": "python -m http.server 8080",
		"docs:validate": "node scripts/validate-docs.js",
		"docs:extract": "node scripts/extract-jsdoc.js",
		"testsprite": "echo \"To run TestSprite tests, use an MCP-compatible IDE and enter: Help me test this project with TestSprite.\"",
		"commit": "pwsh scripts/quick-commit.ps1",
		"auth:seed-admin": "node scripts/seed-admin-user.mjs",
		"import:sheet": "node scripts/import-sheet.mjs",
		"db:verify": "node scripts/verify-db.mjs"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@hookform/resolvers": "^5.2.2",
		"@hugeicons/core-free-icons": "^3.1.1",
		"@hugeicons/react": "^1.1.4",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-checkbox": "^1.1.3",
		"@radix-ui/react-dialog": "^1.1.4",
		"@radix-ui/react-dropdown-menu": "^2.1.4",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-label": "^2.1.1",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tooltip": "^1.1.6",
		"@supabase/supabase-js": "^2.89.0",
		"@t3-oss/env-nextjs": "^0.13.10",
		"@tanstack/react-query": "^5.90.16",
		"@tanstack/react-query-devtools": "^5.91.2",
		"ag-grid-community": "^32.3.3",
		"ag-grid-react": "^32.3.3",
		"better-auth": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"framer-motion": "^12.23.26",
		"kysely": "^0.28.14",
		"ldrs": "^1.1.9",
		"lucide-react": "^0.468.0",
		"motion": "^12.27.0",
		"next": "^15.5.12",
		"nodemailer": "^8.0.1",
		"pg": "^8.20.0",
		"pg-connection-string": "^2.12.0",
		"react": "^19.0.0",
		"react-day-picker": "^9.13.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.72.0",
		"recharts": "^2.15.0",
		"resend": "^6.9.4",
		"sonner": "^1.7.1",
		"tailwind-merge": "^2.6.0",
		"xlsx": "^0.18.5",
		"zod": "^4.3.5",
		"zustand": "^5.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.10",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20.19.37",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^5.1.2",
		"autoprefixer": "^10.4.20",
		"dotenv": "^16.4.7",
		"husky": "^9.1.7",
		"jsdom": "^27.3.0",
		"knip": "^5.88.1",
		"postcss": "^8.5.1",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	},
	"optionalDependencies": {
		"@opentelemetry/api": "^1.9.1"
	},
	"knip": {
		"ignoreBinaries": [
			"python",
			"pwsh"
		]
	}
}
