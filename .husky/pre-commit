#!/usr/bin/env sh

# pendingsystem - Biome Pre-commit Hook
# Ensures all staged files are linted and formatted before commit.

# Get staged files that Biome can handle
STAGED_FILES=$(git diff --name-only --cached --diff-filter=ACMR | grep -E '\.(js|jsx|mjs|cjs|ts|tsx|json|css)$')

if [ -z "$STAGED_FILES" ]; then
    printf '✨ Biome: No files to check, skipping.\n'
    exit 0
fi

printf '🔍 Biome: Running safe fixes on staged files...\n'
npx @biomejs/biome check --write --staged --no-errors-on-unmatched --files-ignore-unknown=true
status=$?

if [ $status -ne 0 ]; then
    printf '⚠️  Biome: Some issues remain. Retrying with unsafe fixes...\n'
    npx @biomejs/biome check --write --unsafe --staged --no-errors-on-unmatched --files-ignore-unknown=true
    status=$?
fi

if [ $status -ne 0 ]; then
    printf '❌ Biome: Still reported issues. Please fix them manually before committing.\n'
    exit $status
fi

# Re-stage modifies files that Biome fixed.
# Using git add -u on the specific files we checked is safest.
# shellcheck disable=SC2086
git add -u $STAGED_FILES

printf '✅ Biome: All staged files are looking good!\n'
